{
  "name": "agent-skill-bridge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm --filter @skillbridge/core build && pnpm -r check",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm format:check && pnpm lint && pnpm check && pnpm test && pnpm build",
    "skillbridge": "node packages/cli/dist/index.js",
    "lint": "eslint ."
  }
}
